# Copy to .env and fill in. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# MySQL connection (defaults match docker-compose)
DB_HOST=localhost
DB_PORT=3306
DB_USER=travel
DB_PASSWORD=travel
DB_NAME=travel_planner

# Comma-separated origins, or * for all
CORS_ORIGINS=*
